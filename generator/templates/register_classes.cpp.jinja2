#include "register_classes.gen.h"
#include "runtime/value_convert.h"
#include <node.h>
#include <node_api.h>
#include <godot_cpp/classes/engine.hpp>

// Classes
{% for item in classes %}
#include "{{ item.include }}"
{% endfor %}

namespace gode {

void register_classes(Napi::Env env, Napi::Object exports) {
    // Register Classes
    {% for item in classes %}
    {{ item.class_name }}Binding::init(env, exports);
    {% endfor %}

    // Register Singletons
    {% for singleton in singletons %}
    {% if singleton.name == "EditorInterface" %}
    if (godot::Engine::get_singleton() && godot::Engine::get_singleton()->is_editor_hint()) {
    {% endif %}
    {
        auto getter_{{ singleton.name }} = [](const Napi::CallbackInfo &info) -> Napi::Value {
            godot::{{ singleton.type }}* instance = godot::{{ singleton.type }}::get_singleton();
            if (!instance) return info.Env().Null();
            return gode::wrap_godot_object(info.Env(), instance, "{{ singleton.binding_type }}");
        };
        if (!exports.Has("{{ singleton.name }}")) {
            exports.DefineProperty(Napi::PropertyDescriptor::Accessor(
                env, exports, "{{ singleton.name }}", getter_{{ singleton.name }}, napi_enumerable, nullptr
            ));
        }
    }
    {% if singleton.name == "EditorInterface" %}
    }
    {% endif %}
    {% endfor %}
}

void reset_class_references() {
    {% for item in classes %}
    if (!{{ item.class_name }}Binding::constructor.IsEmpty()) {
        {{ item.class_name }}Binding::constructor.Reset();
    }
    {% endfor %}
}

} // namespace gode
